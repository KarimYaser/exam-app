      {
        "id": "bcf88ff7-8c86-4257-a4ee-34d915fe0dee",
        "text": "Why are containers important in cloud computing?",
        "examId": "49d60279-fa06-431b-ac77-409ab06378be",
        "immutable": false,
        "createdAt": "2026-03-27T01:13:15.438Z",
        "updatedAt": "2026-03-27T01:13:15.438Z",
        "answers": [
          {
            "id": "9d2f2315-5b79-4f84-a5dc-1e8d26797a74",
            "text": "They provide portability, efficiency, and consistent environments across platforms"
          },
          {
            "id": "a3e9d0e2-5cc0-4881-b0fd-41d9ea9d34cd",
            "text": "They reduce software testing"
          },
          {
            "id": "c211e04d-a9c1-40e9-8800-5726402ebb68",
            "text": "They store backups automatically"
          },
          {
            "id": "03df28ee-a2a6-4854-8cd3-5f3f5bab9c33",
            "text": "They replace the need for cloud security"
          }
        ]
      }
