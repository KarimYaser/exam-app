      {
        "id": "d369d141-715e-4e5e-b3a9-613cdc457139",
        "text": "What is the difference between a container and a virtual machine?",
        "examId": "49d60279-fa06-431b-ac77-409ab06378be",
        "immutable": false,
        "createdAt": "2026-03-27T01:13:15.418Z",
        "updatedAt": "2026-03-27T01:13:15.418Z",
        "answers": [
          {
            "id": "c81fc35d-0e18-471b-9dc2-6ee53da6fa0c",
            "text": "Containers cannot run apps; VMs run only apps"
          },
          {
            "id": "663d04a3-7045-41f0-89ab-066720a22420",
            "text": "VMs are portable; containers cannot run on multiple environments"
          },
          {
            "id": "5a3c9297-fbd1-4752-90ba-19d2cfe54c8e",
            "text": "Containers require physical servers; VMs are cloud-based"
          },
          {
            "id": "36057b64-0dc5-4f65-996a-0c222c77e824",
            "text": "Containers share the host OS and are lightweight; VMs have full OS and more overhead"
          }
        ]
      },
